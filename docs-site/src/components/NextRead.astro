---
/**
 * NextRead — "what to read next" reading-order rail.
 *
 * Linkable cards laid out as a numbered table-of-contents with
 * estimated read time. Designed to compose under any page.
 */
interface Link {
	href: string;
	label: string;
	desc: string;
	time?: string; // "60s", "5 min"
}

interface Props {
	links: Link[];
}

const { links } = Astro.props;
---

<nav class="next-read" aria-label="Continue reading">
	<ol>
		{
			links.map((l, i) => (
				<li>
					<a href={l.href} class="next-read__link">
						<span class="next-read__num">
							{String(i + 1).padStart(2, "0")}
						</span>
						<span class="next-read__body">
							<span class="next-read__label">{l.label}</span>
							<span class="next-read__desc">{l.desc}</span>
						</span>
						{l.time && (
							<span class="next-read__time" aria-label={`reading time ${l.time}`}>
								{l.time}
							</span>
						)}
						<svg
							class="next-read__arrow"
							viewBox="0 0 16 16"
							aria-hidden="true"
						>
							<path
								d="M3 8 H 13 M 9 4 L 13 8 L 9 12"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								stroke-linecap="square"
							/>
						</svg>
					</a>
				</li>
			))
		}
	</ol>
</nav>

<style>
	.next-read ol {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		margin: 0;
		padding: 0;
		list-style: none;
		border-top: 1px solid var(--sl-color-gray-5);
	}

	.next-read li {
		border-bottom: 1px solid var(--sl-color-gray-5);
	}

	.next-read__link {
		display: grid;
		grid-template-columns: auto 1fr auto auto;
		align-items: center;
		gap: 1rem;
		padding: var(--space-4) 0.25rem;
		text-decoration: none;
		color: var(--sl-color-white);
		transition: background 140ms ease, padding 140ms ease;
	}

	.next-read__link:hover,
	.next-read__link:focus-visible {
		background: color-mix(in oklab, var(--sl-color-text-accent) 6%, transparent);
		padding-left: 0.6rem;
		padding-right: 0.6rem;
	}

	.next-read__link:focus-visible {
		outline: 2px solid var(--sl-color-text-accent);
		outline-offset: 2px;
	}

	.next-read__num {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		color: var(--sl-color-text-accent);
		min-width: 2.2rem;
	}

	.next-read__body {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		min-width: 0;
	}

	.next-read__label {
		font-family: var(--font-sans);
		font-size: 1rem;
		font-weight: 600;
		line-height: var(--lh-tight);
	}

	.next-read__desc {
		font-size: 0.86rem;
		line-height: var(--lh-prose);
		color: var(--sl-color-gray-2);
	}

	.next-read__time {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.04em;
		color: var(--sl-color-gray-3);
		font-variant-numeric: tabular-nums;
	}

	.next-read__arrow {
		width: 16px;
		height: 16px;
		color: var(--sl-color-gray-3);
		transition: transform 160ms ease, color 160ms ease;
	}

	.next-read__link:hover .next-read__arrow,
	.next-read__link:focus-visible .next-read__arrow {
		transform: translateX(3px);
		color: var(--sl-color-text-accent);
	}

	@media (max-width: 40rem) {
		.next-read__link {
			grid-template-columns: auto 1fr auto;
		}
		.next-read__time {
			grid-column: 2;
			grid-row: 2;
			justify-self: start;
			padding-top: 0.15rem;
		}
		.next-read__arrow {
			grid-column: 3;
			grid-row: 1 / span 2;
		}
	}
</style>
