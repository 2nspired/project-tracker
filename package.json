{
	"name": "pigeon-mcp",
	"version": "4.2.0",
	"private": true,
	"scripts": {
		"dev": "tsx scripts/dev.ts",
		"setup": "tsx scripts/setup.mts",
		"postinstall": "prisma generate",
		"build": "prisma generate && next build",
		"start": "next start",
		"lint": "biome check src/",
		"lint:fix": "biome check --write src/",
		"format": "biome format --write src/",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"db:generate": "prisma generate",
		"db:push": "prisma db push",
		"db:migrate": "prisma migrate dev",
		"db:studio": "prisma studio",
		"mcp:dev": "MCP_SERVER_BRAND=pigeon tsx src/mcp/server.ts",
		"migrate-rebrand": "tsx scripts/migrate-rebrand.ts",
		"docs:sync": "tsx scripts/sync-tool-docs.ts",
		"docs:check": "tsx scripts/sync-tool-docs.ts --check",
		"release": "tsx scripts/release.ts",
		"db:seed": "tsx prisma/seed.ts",
		"db:cleanup-orphan-boards": "tsx scripts/cleanup-orphan-boards.ts",
		"service:install": "tsx scripts/service.ts install",
		"service:uninstall": "tsx scripts/service.ts uninstall",
		"service:start": "tsx scripts/service.ts start",
		"service:stop": "tsx scripts/service.ts stop",
		"service:disable": "tsx scripts/service.ts disable",
		"service:enable": "tsx scripts/service.ts enable",
		"service:status": "tsx scripts/service.ts status",
		"service:logs": "tsx scripts/service.ts logs",
		"service:update": "tsx scripts/service.ts update",
		"docs:dev": "npm --prefix docs-site run dev",
		"docs:build": "npm --prefix docs-site run build",
		"docs:preview": "npm --prefix docs-site run preview",
		"docs:install": "npm --prefix docs-site install"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@prisma/adapter-better-sqlite3": "^7.6.0",
		"@prisma/adapter-pg": "^7.6.0",
		"@prisma/client": "^7.6.0",
		"@supabase/ssr": "^0.10.0",
		"@supabase/supabase-js": "^2.101.0",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tanstack/react-query": "^5.95.2",
		"@toon-format/toon": "^2.1.0",
		"@trpc/client": "^11.16.0",
		"@trpc/react-query": "^11.16.0",
		"@trpc/server": "^11.16.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"js-yaml": "^4.1.0",
		"lucide-react": "^1.7.0",
		"next": "16.2.1",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-markdown": "^10.1.0",
		"remark-breaks": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"server-only": "latest",
		"sonner": "^2.0.7",
		"superjson": "^2.2.6",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@tailwindcss/postcss": "^4.2.2",
		"@testing-library/react": "latest",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^5.1.3",
		"dotenv": "^17.3.1",
		"jsdom": "^29.0.1",
		"prisma": "^7.6.0",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5",
		"vitest": "^4.1.2"
	}
}
