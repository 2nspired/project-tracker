generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id              String   @id @default(uuid())
  name            String
  description     String?
  color           String   @default("slate")
  slug            String   @unique
  favorite        Boolean  @default(false)
  repoPath        String?  @unique @map("repo_path")
  defaultBoardId  String?  @unique @map("default_board_id")
  nextCardNumber  Int      @default(1) @map("next_card_number")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  boards         Board[]
  defaultBoard   Board?   @relation("DefaultBoard", fields: [defaultBoardId], references: [id], onDelete: SetNull)
  labels         Label[]
  tags           Tag[]
  cards          Card[]
  notes          Note[]
  milestones     Milestone[]
  gitLinks       GitLink[]
  claims         Claim[]
  tokenUsageEvents TokenUsageEvent[]

  @@map("project")
}

model Milestone {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  name        String
  description String?
  targetDate  DateTime? @map("target_date")
  position    Int       @default(0)
  // "active" | "archived" — archived milestones are hidden from the picker
  // by default but kept in the schema so historical card assignments
  // continue to resolve. v4.2 governance: avoids ad-hoc deletion when a
  // milestone has shipped or turned out premature.
  state       String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cards   Card[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("milestone")
}

model Label {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  name      String
  color     String @default("#6b7280")
  createdAt DateTime @default(now()) @map("created_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cardLabels CardLabel[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("label")
}

// Project-scoped, normalized tag entity introduced in v4.2.
//
// Replaces the legacy `Card.tags String @default("[]")` JSON column,
// which stays populated through v4.2 as a read fallback and is dropped
// in v5. The split between `slug` (canonical, immutable identifier;
// kebab-case via `slugify()`) and `label` (mutable display) keeps
// `mergeTags` and `renameTag` cheap.
model Tag {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  slug      String
  label     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cardTags CardTag[]

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("tag")
}

model Board {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  name        String
  description String?
  // Threshold (days) for the "stale in-progress" reconciler. null disables
  // the check for this board; any positive integer is the silence window
  // before a card in an `active`-role column is flagged as stalled.
  staleInProgressDays Int? @default(3) @map("stale_in_progress_days")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns           Column[]
  notes             Note[]
  defaultForProject Project? @relation("DefaultBoard")

  @@index([projectId])
  @@map("board")
}

model Column {
  id          String   @id @default(uuid())
  boardId     String   @map("board_id")
  name        String
  description String?
  position    Int
  role        String?  // backlog, todo, active, review, done, parking
  isParking   Boolean  @default(false) @map("is_parking")
  color       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
  @@map("column")
}

model Card {
  id          String   @id @default(uuid())
  columnId    String   @map("column_id")
  projectId   String   @map("project_id")
  number      Int
  title       String
  description String?
  position    Int
  priority    String   @default("NONE")
  tags        String   @default("[]")
  createdBy   String   @default("HUMAN") @map("created_by")
  milestoneId String?   @map("milestone_id")
  dueDate     DateTime? @map("due_date")
  metadata     String   @default("{}") // JSON object for agent context (not rendered in UI)
  lastEditedBy String?  @map("last_edited_by") // Agent/actor who last modified this card
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  column        Column          @relation(fields: [columnId], references: [id], onDelete: Cascade)
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone     Milestone?      @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  checklists    ChecklistItem[]
  comments      Comment[]
  activities    Activity[]
  cardLabels    CardLabel[]
  cardTags      CardTag[]
  relationsFrom CardRelation[]  @relation("RelationFrom")
  relationsTo   CardRelation[]  @relation("RelationTo")
  gitLinks      GitLink[]
  claims        Claim[]
  notes         Note[]
  tokenUsageEvents TokenUsageEvent[]

  @@unique([projectId, number])
  @@index([columnId])
  @@index([projectId])
  @@index([milestoneId])
  @@index([priority])
  @@index([updatedAt])
  @@index([createdBy, projectId])
  @@map("card")
}

model ChecklistItem {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  text      String
  completed Boolean  @default(false)
  position  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@map("checklist_item")
}

model Comment {
  id         String   @id @default(uuid())
  cardId     String   @map("card_id")
  content    String
  authorType String   @default("HUMAN") @map("author_type")
  authorName String?  @map("author_name")
  createdAt  DateTime @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@map("comment")
}

model Activity {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  action    String
  details   String?
  // Short agent-written rationale for the action (e.g. "promoting to In Progress:
  // starting auth implementation"). Required on AGENT moves and deletes so that
  // every destructive or state-changing write surfaces its reasoning.
  intent    String?
  actorType String   @default("HUMAN") @map("actor_type")
  actorName String?  @map("actor_name")
  createdAt DateTime @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([cardId, createdAt])
  @@map("activity")
}

model CardLabel {
  cardId  String @map("card_id")
  labelId String @map("label_id")

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
  @@map("card_label")
}

// Junction between Card and Tag (v4.2). Composite PK on (cardId, tagId)
// gives implicit dedupe — a card can hold a given tag at most once.
// Cascade on both sides so deleting a card or tag cleans the junction.
model CardTag {
  cardId String @map("card_id")
  tagId  String @map("tag_id")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([cardId, tagId])
  @@index([tagId])
  @@map("card_tag")
}

model Note {
  id        String    @id @default(uuid())
  projectId String?   @map("project_id")
  kind      String    @default("general")
  title     String
  content   String    @default("")
  tags      String    @default("[]")
  author    String    @default("HUMAN")
  cardId    String?   @map("card_id")
  boardId   String?   @map("board_id")
  metadata  String    @default("{}")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  card    Card?    @relation(fields: [cardId], references: [id], onDelete: SetNull)
  board   Board?   @relation(fields: [boardId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, kind])
  @@index([boardId, kind])
  @@index([cardId])
  @@index([kind])
  @@index([expiresAt])
  @@index([updatedAt])
  @@map("note")
}

// ─── AI Context Engine Models ─────────────────────────────────────

model CardRelation {
  id         String   @id @default(uuid())
  fromCardId String   @map("from_card_id")
  toCardId   String   @map("to_card_id")
  type       String   // blocks, related, parent
  createdAt  DateTime @default(now()) @map("created_at")

  fromCard Card @relation("RelationFrom", fields: [fromCardId], references: [id], onDelete: Cascade)
  toCard   Card @relation("RelationTo", fields: [toCardId], references: [id], onDelete: Cascade)

  @@unique([fromCardId, toCardId, type])
  @@index([fromCardId])
  @@index([toCardId])
  @@map("card_relation")
}

model GitLink {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  cardId     String   @map("card_id")
  commitHash String   @map("commit_hash")
  message    String   @default("")
  author     String   @default("")
  commitDate DateTime @default(now()) @map("commit_date")
  filePaths  String   @default("[]") @map("file_paths") // JSON array
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([projectId, commitHash, cardId])
  @@index([projectId])
  @@index([cardId])
  @@map("git_link")
}

// ─── Unified knowledge primitive (docs/RFC-NOTE-CLAIM-PRIMITIVES.md) ─

model Claim {
  id             String    @id @default(uuid())
  projectId      String    @map("project_id")
  kind           String    // 'context' | 'code' | 'measurement' | 'decision'
  statement      String    // one-sentence assertion (list-row display)
  body           String    @default("")        // markdown elaboration
  evidence       String    @default("{}")      // JSON: { files?, symbols?, urls?, cardIds? }
  payload        String    @default("{}")      // JSON: kind-specific structured data
  author         String    @default("AGENT")   // AGENT_NAME or HUMAN
  cardId         String?   @map("card_id")
  status         String    @default("active")  // 'active' | 'superseded' | 'retired'
  supersedesId   String?   @map("supersedes_id")
  supersededById String?   @map("superseded_by_id")
  recordedAtSha  String?   @map("recorded_at_sha")
  verifiedAt     DateTime? @map("verified_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  card    Card?   @relation(fields: [cardId],    references: [id], onDelete: SetNull)
  // supersedesId / supersededById are plain FK-less string IDs,
  // matching the Decision model convention — cross-linking is
  // enforced in the tool handler.

  @@index([projectId])
  @@index([projectId, kind])
  @@index([projectId, status])
  @@index([cardId])
  @@index([kind, status])
  @@index([updatedAt])
  @@map("claim")
}

model ToolCallLog {
  id           String   @id @default(uuid())
  toolName     String   @map("tool_name")
  toolType     String   @map("tool_type")
  agentName    String   @map("agent_name")
  sessionId    String   @map("session_id")
  durationMs   Int      @map("duration_ms")
  success      Boolean
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([agentName])
  @@index([sessionId])
  @@index([createdAt])
  @@index([toolName, createdAt])
  @@index([agentName, createdAt])
  @@map("tool_call_log")
}

// ─── Token usage tracking (#96) ────────────────────────────────────

// Singleton process-wide settings. Currently holds only token pricing
// overrides; structured as JSON so future settings can land without
// schema churn. Read via `resolvePricing()` which fail-softs to
// `DEFAULT_PRICING` on parse error.
model AppSettings {
  id           String   @id @default("singleton")
  tokenPricing String   @default("{}") @map("token_pricing")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// Per-session-per-model token usage. One row per (sessionId, model);
// `recordFromTranscript` is delete-and-reinsert idempotent on
// `sessionId`. The 5-column split (input + output + cacheRead +
// cacheCreation1h + cacheCreation5m) preserves Anthropic's pricing
// fidelity (1h ≈ 2× input, 5m ≈ 1.25× input); lumping would break
// later when the user changes pricing. OpenAI sessions store 0 for
// the cacheCreation columns (caching is automatic, no creation cost).
model TokenUsageEvent {
  id                    String   @id @default(uuid())
  sessionId             String   @map("session_id")
  projectId             String   @map("project_id")
  cardId                String?  @map("card_id")
  agentName             String   @map("agent_name")
  model                 String
  inputTokens           Int      @default(0) @map("input_tokens")
  outputTokens          Int      @default(0) @map("output_tokens")
  cacheReadTokens       Int      @default(0) @map("cache_read_tokens")
  cacheCreation1hTokens Int      @default(0) @map("cache_creation_1h_tokens")
  cacheCreation5mTokens Int      @default(0) @map("cache_creation_5m_tokens")
  recordedAt            DateTime @default(now()) @map("recorded_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  card    Card?   @relation(fields: [cardId],    references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([projectId])
  @@index([projectId, recordedAt])
  @@index([cardId])
  @@map("token_usage_event")
}
