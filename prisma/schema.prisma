generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id              String   @id @default(uuid())
  name            String
  description     String?
  color           String   @default("slate")
  slug            String   @unique
  favorite        Boolean  @default(false)
  repoPath        String?  @map("repo_path")
  projectPrompt   String?  @map("project_prompt")
  nextCardNumber  Int      @default(1) @map("next_card_number")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  boards         Board[]
  labels         Label[]
  cards          Card[]
  notes          Note[]
  milestones     Milestone[]
  decisions      Decision[]
  gitLinks       GitLink[]
  contextEntries PersistentContextEntry[]
  codeFacts         CodeFact[]
  measurementFacts  MeasurementFact[]

  @@map("project")
}

model Milestone {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  name        String
  description String?
  targetDate  DateTime? @map("target_date")
  position    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cards   Card[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("milestone")
}

model Label {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  name      String
  color     String @default("#6b7280")
  createdAt DateTime @default(now()) @map("created_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cardLabels CardLabel[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("label")
}

model Board {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns   Column[]
  handoffs  SessionHandoff[]
  scratches AgentScratch[]

  @@index([projectId])
  @@map("board")
}

model Column {
  id          String   @id @default(uuid())
  boardId     String   @map("board_id")
  name        String
  description String?
  position    Int
  role        String?  // backlog, todo, active, review, done, parking
  isParking   Boolean  @default(false) @map("is_parking")
  color       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
  @@map("column")
}

model Card {
  id          String   @id @default(uuid())
  columnId    String   @map("column_id")
  projectId   String   @map("project_id")
  number      Int
  title       String
  description String?
  position    Int
  priority    String   @default("NONE")
  tags        String   @default("[]")
  assignee    String?
  createdBy   String   @default("HUMAN") @map("created_by")
  milestoneId String?   @map("milestone_id")
  dueDate     DateTime? @map("due_date")
  metadata    String   @default("{}") // JSON object for agent context (not rendered in UI)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  column        Column          @relation(fields: [columnId], references: [id], onDelete: Cascade)
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone     Milestone?      @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  checklists    ChecklistItem[]
  comments      Comment[]
  activities    Activity[]
  cardLabels    CardLabel[]
  relationsFrom CardRelation[]  @relation("RelationFrom")
  relationsTo   CardRelation[]  @relation("RelationTo")
  decisions     Decision[]
  gitLinks      GitLink[]

  @@unique([projectId, number])
  @@index([columnId])
  @@index([projectId])
  @@index([milestoneId])
  @@index([priority])
  @@index([assignee])
  @@index([updatedAt])
  @@index([createdBy, projectId])
  @@map("card")
}

model ChecklistItem {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  text      String
  completed Boolean  @default(false)
  position  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@map("checklist_item")
}

model Comment {
  id         String   @id @default(uuid())
  cardId     String   @map("card_id")
  content    String
  authorType String   @default("HUMAN") @map("author_type")
  authorName String?  @map("author_name")
  createdAt  DateTime @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@map("comment")
}

model Activity {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  action    String
  details   String?
  actorType String   @default("HUMAN") @map("actor_type")
  actorName String?  @map("actor_name")
  createdAt DateTime @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([cardId, createdAt])
  @@map("activity")
}

model CardLabel {
  cardId  String @map("card_id")
  labelId String @map("label_id")

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
  @@map("card_label")
}

model Note {
  id        String   @id @default(uuid())
  projectId String?  @map("project_id")
  title     String
  content   String   @default("")
  tags      String   @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([updatedAt])
  @@map("note")
}

// ─── AI Context Engine Models ─────────────────────────────────────

model CardRelation {
  id         String   @id @default(uuid())
  fromCardId String   @map("from_card_id")
  toCardId   String   @map("to_card_id")
  type       String   // blocks, related, parent
  createdAt  DateTime @default(now()) @map("created_at")

  fromCard Card @relation("RelationFrom", fields: [fromCardId], references: [id], onDelete: Cascade)
  toCard   Card @relation("RelationTo", fields: [toCardId], references: [id], onDelete: Cascade)

  @@unique([fromCardId, toCardId, type])
  @@index([fromCardId])
  @@index([toCardId])
  @@map("card_relation")
}

model SessionHandoff {
  id        String   @id @default(uuid())
  boardId   String   @map("board_id")
  agentName String   @map("agent_name")
  workingOn String   @default("[]") @map("working_on") // JSON array
  findings  String   @default("[]") // JSON array
  nextSteps String   @default("[]") @map("next_steps") // JSON array
  blockers  String   @default("[]") // JSON array
  summary   String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt])
  @@map("session_handoff")
}

model Decision {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  cardId       String?  @map("card_id")
  title        String
  status       String   @default("proposed") // proposed, accepted, rejected, superseded
  decision     String
  alternatives String   @default("[]") // JSON array
  rationale    String   @default("")
  author       String   @default("AGENT")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  card    Card?   @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([cardId])
  @@map("decision")
}

model AgentScratch {
  id        String    @id @default(uuid())
  boardId   String    @map("board_id")
  agentName String    @map("agent_name")
  key       String
  value     String
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, agentName, key])
  @@index([expiresAt])
  @@map("agent_scratch")
}

model GitLink {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  cardId     String   @map("card_id")
  commitHash String   @map("commit_hash")
  message    String   @default("")
  author     String   @default("")
  commitDate DateTime @default(now()) @map("commit_date")
  filePaths  String   @default("[]") @map("file_paths") // JSON array
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([projectId, commitHash, cardId])
  @@index([projectId])
  @@index([cardId])
  @@map("git_link")
}

model PersistentContextEntry {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  claim         String   // The fact or assertion
  rationale     String   @default("") // Why this matters
  application   String   @default("") // How to apply this knowledge
  details       String   @default("[]") // JSON string[] — supporting details
  author        String   @default("AGENT") // Who recorded this (AGENT or HUMAN)
  audience      String   @default("all") // Who should see it (all, agent, human)
  citedFiles    String   @default("[]") @map("cited_files") // JSON string[] — file paths this fact references
  recordedAtSha String?  @map("recorded_at_sha") // Git SHA when this was recorded
  surface       String   @default("indexed") // ambient | indexed | surfaced
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([surface])
  @@index([projectId, surface])
  @@map("persistent_context_entry")
}

model CodeFact {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  path           String   // File path (relative to repo root)
  symbol         String?  // Optional symbol name (function, class, etc.)
  fact           String   // The factual assertion about this code
  author         String   @default("AGENT") // Who recorded this (AGENT or HUMAN)
  recordedAtSha  String?  @map("recorded_at_sha") // Git SHA when recorded
  needsRecheck   Boolean  @default(false) @map("needs_recheck") // Advisory flag
  lastVerifiedAt DateTime? @map("last_verified_at") // Last time someone confirmed this is still true
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, path])
  @@index([needsRecheck])
  @@map("code_fact")
}

model MeasurementFact {
  id           String    @id @default(uuid())
  projectId    String    @map("project_id")
  value        Float                          // The measured value
  unit         String                         // e.g. "seconds", "ms", "MB"
  description  String                         // What was measured
  env          String    @default("{}")       // JSON key-value pairs of dependencies
  path         String?                        // Optional file path (relative to repo root)
  symbol       String?                        // Optional function/symbol name
  author       String    @default("AGENT")
  recordedAt   DateTime  @default(now()) @map("recorded_at")
  ttl          Int?                           // Optional TTL in days
  needsRecheck Boolean   @default(false) @map("needs_recheck")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([needsRecheck])
  @@map("measurement_fact")
}
